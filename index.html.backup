      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "45.9",
        "longitude": "-74.0"
      },
      "telephone": "(450) 226-3838",
      "email": "info@jdametals.com",
      "url": "https://jdametals.com",
      "priceRange": "$$",
      "openingHours": "Mo-Fr 07:00-17:00",
      "areaServed": "Quebec",
      "serviceType": "Fabrication métallurgique",
      "description": "Expert en fabrication d'acier structural au Québec depuis 30 ans. Conception, fabrication et installation.",
      "foundingDate": "1994"
    }
    </script>
</head>

