    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              'warm-white': '#F5F0EB',
              'warm-gray': '#E8E0D8',
              'forge-orange': '#C45A28',
              'dark-charcoal': '#2C2C2C',
              'warm-bronze': '#8B7355',
              'text-primary': '#1A1A1A',
              'text-secondary': '#666666',
              'border-muted': '#CCBFB0'
            },
            fontFamily: {
              'grotesk': ['Space Grotesk', 'sans-serif'],
              'sans': ['DM Sans', 'sans-serif'],
              'mono': ['Space Mono', 'monospace']
            }
          }
        }
      }
    </script>
    
    <!-- Critical CSS -->
    <style>
      /* Page Load Animation */
      .page-loader {
        position: fixed;
        inset: 0;
        background: #C45A28;
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.8s ease-in-out;
      }
      .page-loader.loaded {
        transform: translateY(-100%);
      }
      
      /* Custom Cursor */
      .cursor {
        position: fixed;
        width: 8px;
        height: 8px;
        background: #C45A28;
        border-radius: 50%;
        pointer-events: none;
        z-index: 9998;
        mix-blend-mode: difference;
        transition: transform 0.15s ease, width 0.3s ease, height 0.3s ease;
      }
      .cursor-outline {
        position: fixed;
        width: 40px;
        height: 40px;
        border: 1px solid #C45A28;
        border-radius: 50%;
        pointer-events: none;
        z-index: 9997;
        mix-blend-mode: difference;
        transition: transform 0.3s ease;
      }
      .cursor--hover {
        width: 60px;
        height: 60px;
        background-color: rgba(196, 90, 40, 0.2);
      }
      .cursor-outline--hover {
        width: 80px;
        height: 80px;
      }
      @media (pointer: coarse) {
        .cursor, .cursor-outline { display: none; }
      }
      
      /* Navigation */
      .nav-blur {
        backdrop-filter: blur(10px);
        background: rgba(245, 240, 235, 0.95);
      }
      
      /* Film Grain */
      .grain::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.4'/%3E%3C/svg%3E");
        opacity: 0.03;
        pointer-events: none;
        z-index: 100;
        animation: grain 8s steps(10) infinite;
      }
      @keyframes grain {
        0%, 100% { transform: translate(0, 0); }
        10% { transform: translate(-5%, -10%); }
        30% { transform: translate(3%, -15%); }
        50% { transform: translate(12%, 9%); }
        70% { transform: translate(-9%, 4%); }
        90% { transform: translate(-1%, -7%); }
      }
      
      /* Split Text Hidden */
      .split-chars {
        opacity: 0;
        transform: translateY(30px);
      }
      
      /* Video Poster */
      video {
        object-fit: cover;
      }
      
      /* Magnetic Button Effect */
      .magnetic {
        transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      }
      
      /* Image Reveal */
      .image-reveal {
        position: relative;
        overflow: hidden;
      }
      .image-reveal::before {
        content: '';
        position: absolute;
        inset: 0;
        background: #C45A28;
        z-index: 2;
        transform: translateX(0);
        transition: transform 1.2s ease-out;
      }
      .image-reveal.revealed::before {
        transform: translateX(100%);
      }
      .image-reveal img {
        transform: scale(1.2);
        transition: transform 1.2s ease-out;
      }
      .image-reveal.revealed img {
        transform: scale(1);
      }
    </style>
    
    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json">
